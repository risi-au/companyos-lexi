{
  "name": "companyos",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint . --ignore-pattern \"**/*.fixture.ts\" --ignore-pattern \"USER DATA/**\" && node scripts/check-encoding.mjs && node scripts/validate-tokens.mjs && turbo lint",
    "check:encoding": "node scripts/check-encoding.mjs",
    "validate-tokens": "node scripts/validate-tokens.mjs",
    "test": "vitest run --pool=forks --maxWorkers=1",
    "typecheck": "turbo typecheck",
    "mcp": "node packages/mcp/dist/stdio.js",
    "infra:up": "docker compose -f infra/docker-compose.dev.yml --env-file .env up -d",
    "infra:down": "docker compose -f infra/docker-compose.dev.yml --env-file .env down -v",
    "db:migrate": "pnpm --filter @companyos/db db:migrate",
    "db:seed": "pnpm --filter @companyos/db db:seed",
    "db:seed-demo": "pnpm --filter @companyos/api seed-demo"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.28.0",
    "eslint-import-resolver-typescript": "^4.4.1",
    "eslint-plugin-boundaries": "^5.0.1",
    "globals": "^16.2.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  }
}
