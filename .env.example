DATABASE_URL=postgresql://companyos:devpassword123@localhost:5432/companyos

# === infra (docker-compose.dev + litellm.config) ===
# Postgres shared user/pass (compose uses these for container init + internal URLs)
POSTGRES_USER=companyos
POSTGRES_PASSWORD=devpassword123

# LiteLLM
LITELLM_MASTER_KEY=sk-1234567890abcdef1234567890abcdef

# Provider API keys (placeholders — fill real values in local .env only)
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-with-real
DEEPSEEK_API_KEY=sk-deepseek-placeholder-replace-with-real
OPENAI_API_KEY=sk-openai-placeholder-replace-with-real

# Plane CE (side-by-side): after running its setup.sh, edit its plane.env to point to our postgres
# Example (in Plane's env):
# DATABASE_URL=postgresql://companyos:devpassword123@localhost:5432/plane
# POSTGRES_DB=plane
# WEB_URL=http://localhost:8080
# LISTEN_HTTP_PORT=8080MOONSHOT_API_KEY=

# Better Auth (email/password only for M2-03)
BETTER_AUTH_SECRET=change-this-to-a-long-random-secret-in-real-env

