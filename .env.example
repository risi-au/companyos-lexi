DATABASE_URL=postgresql://companyos:devpassword123@localhost:5432/companyos

# === infra (docker-compose.dev + litellm.config) ===
# Postgres shared user/pass (compose uses these for container init + internal URLs)
POSTGRES_USER=companyos
POSTGRES_PASSWORD=devpassword123

# LiteLLM
LITELLM_MASTER_KEY=sk-1234567890abcdef1234567890abcdef
BRAIN_LITELLM_API_KEY=sk-brain-virtual-key-placeholder
BRAIN_RUN_TOKEN_CEILING=24000
BRAIN_MONTHLY_TOKEN_BUDGET=1000000
LITELLM_EMBED_KEY=sk-litellm-embed-virtual-key-placeholder
LITELLM_EMBED_MODEL=replace-with-embedding-model-in-local-env
EMBEDDING_DIMENSIONS=1536

# Provider API keys (placeholders — fill real values in local .env only)
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-with-real
DEEPSEEK_API_KEY=sk-deepseek-placeholder-replace-with-real
OPENAI_API_KEY=sk-openai-placeholder-replace-with-real

# Plane CE (side-by-side): after running its setup.sh, edit its plane.env to point to our postgres
# Example (in Plane's env):
# DATABASE_URL=postgresql://companyos:devpassword123@localhost:5432/plane
# POSTGRES_DB=plane
# WEB_URL=http://localhost:8080
# LISTEN_HTTP_PORT=8080
MOONSHOT_API_KEY=sk-moonshot-placeholder-replace-with-real

# Better Auth
BETTER_AUTH_SECRET=change-this-to-a-long-random-secret-in-real-env
# Optional Google social login. Both values must be non-empty to enable the Google
# button and provider; leave either blank to keep email/password-only auth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === n8n (M2-05) ===
# Basic auth enabled for dev UI; do not use same secrets in prod multi-tenant
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=n8n
N8N_BASIC_AUTH_PASSWORD=devn8npass123
# Webhook base for self calls from inside docker (host.docker.internal reaches host:3000)
N8N_WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=UTC
# (n8n uses sqlite by default in compose; no shared DB)

# Plane webhooks (M2-05)
PLANE_WEBHOOK_SECRET=plane-whsec-dev-placeholder-replace-in-real-env

# GitHub webhook ingestion (M7-02). Self-generated HMAC secret, per environment:
# `openssl rand -hex 32`, then use the SAME value in the GitHub webhook config
# (Payload URL <COMPANYOS_URL>/api/webhooks/github, events: Pushes + Pull requests).
GITHUB_WEBHOOK_SECRET=github-whsec-dev-placeholder-replace-in-real-env
# Public URL Plane should call for CompanyOS webhook ingestion.
PLANE_WEBHOOK_URL=http://host.docker.internal:3000/api/v1/webhooks/plane

# CompanyOS public base URL used in generated workbench AGENTS.md files.
COMPANYOS_URL=http://localhost:3000
# Public MCP endpoint. Defaults conceptually to ${COMPANYOS_URL}/api/mcp; set
# explicitly because env loaders do not all expand variables.
MCP_PUBLIC_URL=http://localhost:3000/api/mcp
# Comma-separated origins allowed to call /api/mcp when an Origin header exists.
MCP_ALLOWED_ORIGINS=http://localhost:3000
# Remote MCP HTTP guardrails.
MCP_MAX_BODY_BYTES=1048576
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX=120

# GitHub workbench provisioning (org creation remains manual).
GITHUB_ORG=brissie-digital
GITHUB_TOKEN=ghp-placeholder-replace-with-real
# Optional for GitHub Enterprise / tests; defaults to https://api.github.com.
# GITHUB_API_URL=https://api.github.com
# Central skills repo name inside GITHUB_ORG. Used by the sync_skills MCP tool.
SKILLS_REPO=companyos-skills

# Instance identity (M4-01)
# INSTANCE_NAME sets root scope name + UI header + titles. Default "CompanyOS".
# Set to your org/instance e.g. "Brissie Digital"
INSTANCE_NAME=Brissie Digital

# Credential vault (M8-09). Optional for boot; required to write/read vault values.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
COS_VAULT_KEY=replace-with-32-byte-base64-key

# --- prod (VPS) ---
# Required for infra/docker-compose.prod.yml image tags. No default; releases move tag-to-tag.
COMPANYOS_TAG=v0.x.y
# Host-local port for the OS app. Point the VPS tunnel/proxy at 127.0.0.1:${OS_PORT}.
OS_PORT=3000
# Optional LiteLLM log level for prod compose.
LITELLM_LOG=INFO
# Required for persistent n8n credentials in prod.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-prod-secret

# Brain engine scheduled trigger token. Must belong to a principal with root admin
# grant so it can register/report the brain-engine capability. The brain-cron sidecar
# is opt-in: set COMPOSE_PROFILES=brain alongside this token to enable it.
BRAIN_ENGINE_TOKEN=cos_replace_with_root_admin_brain_token
BRAIN_INGEST_CRON=0 2 * * *
BRAIN_LINT_CRON=0 3 * * 0
# Backup sidecar (enable with COMPOSE_PROFILES=backup in prod/staging). The sidecar
# runs nightly at 03:00 UTC, dumps BACKUP_DATABASES, includes /host-env/.env in the
# encrypted tar, uploads to S3-compatible storage, verifies with HEAD, then prunes.
BACKUP_DATABASES=companyos,litellm
BACKUP_ENCRYPTION_KEY=replace-with-long-random-escrowed-backup-key
BACKUP_S3_ENDPOINT=https://example-account.r2.cloudflarestorage.com
BACKUP_S3_BUCKET=companyos-backups
BACKUP_S3_ACCESS_KEY_ID=replace-with-scoped-object-readwrite-key-id
BACKUP_S3_SECRET_ACCESS_KEY=replace-with-scoped-object-readwrite-secret
# Cloudflare R2 uses region "auto"; other S3-compatible providers may need a real region.
BACKUP_S3_REGION=auto
# Prefix inside the bucket; daily/ and weekly/ are created below this prefix.
BACKUP_S3_PREFIX=companyos
BACKUP_SCHEDULE_UTC=03:00
# Optional capability reporting. Register capability "db-backup" on BACKUP_REPORT_SCOPE
# and give this token editor/agent access there. When unset, backups still run and log.
BACKUP_REPORT_TOKEN=
BACKUP_REPORT_URL=http://os:3000/api/v1/capabilities/report-run
BACKUP_REPORT_SCOPE=root
# Public n8n host/protocol when exposed through a tunnel or proxy.
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
# Optional Plane CE side-by-side integration values for OS task links/API calls.
PLANE_BASE_URL=https://plane.example.com
PLANE_API_TOKEN=plane-api-token-placeholder
PLANE_WORKSPACE_SLUG=companyos
