DATABASE_URL=postgresql://companyos:devpassword123@localhost:5432/companyos

# === infra (docker-compose.dev + litellm.config) ===
# Postgres shared user/pass (compose uses these for container init + internal URLs)
POSTGRES_USER=companyos
POSTGRES_PASSWORD=devpassword123

# LiteLLM
LITELLM_MASTER_KEY=sk-1234567890abcdef1234567890abcdef

# Provider API keys (placeholders — fill real values in local .env only)
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-with-real
DEEPSEEK_API_KEY=sk-deepseek-placeholder-replace-with-real
OPENAI_API_KEY=sk-openai-placeholder-replace-with-real

# Plane CE (side-by-side): after running its setup.sh, edit its plane.env to point to our postgres
# Example (in Plane's env):
# DATABASE_URL=postgresql://companyos:devpassword123@localhost:5432/plane
# POSTGRES_DB=plane
# WEB_URL=http://localhost:8080
# LISTEN_HTTP_PORT=8080MOONSHOT_API_KEY=

# Better Auth (email/password only for M2-03)
BETTER_AUTH_SECRET=change-this-to-a-long-random-secret-in-real-env

# === n8n (M2-05) ===
# Basic auth enabled for dev UI; do not use same secrets in prod multi-tenant
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=n8n
N8N_BASIC_AUTH_PASSWORD=devn8npass123
# Webhook base for self calls from inside docker (host.docker.internal reaches host:3000)
N8N_WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=UTC
# (n8n uses sqlite by default in compose; no shared DB)

# Plane webhooks (M2-05)
PLANE_WEBHOOK_SECRET=plane-whsec-dev-placeholder-replace-in-real-env
# Public URL Plane should call for CompanyOS webhook ingestion.
PLANE_WEBHOOK_URL=http://host.docker.internal:3000/api/v1/webhooks/plane

# CompanyOS public base URL used in generated workbench AGENTS.md files.
COMPANYOS_URL=http://localhost:3000

# GitHub workbench provisioning (org creation remains manual).
GITHUB_ORG=brissie-digital
GITHUB_TOKEN=ghp-placeholder-replace-with-real
# Optional for GitHub Enterprise / tests; defaults to https://api.github.com.
# GITHUB_API_URL=https://api.github.com

# Instance identity (M4-01)
# INSTANCE_NAME sets root scope name + UI header + titles. Default "CompanyOS".
# Set to your org/instance e.g. "Brissie Digital"
INSTANCE_NAME=Brissie Digital
